{
  "settings": {
    "analysis": {
      "analyzer": {
        "nori_analyzer": {
          "type": "custom",
          "tokenizer": "nori_tokenizer",
          "filter": ["lowercase", "nori_part_of_speech"]
        },
        "english_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "english_possessive_stemmer", "porter_stem"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "id":            { "type": "long" },
      "title":         { "type": "text", "analyzer": "english_analyzer",
        "fields": { "ko": { "type": "text", "analyzer": "nori_analyzer" } }
      },
      "description":   { "type": "text", "analyzer": "english_analyzer",
        "fields": { "ko": { "type": "text", "analyzer": "nori_analyzer" } }
      },
      "director":      { "type": "text", "analyzer": "nori_analyzer" },
      "genres":        { "type": "keyword",
        "fields": { "text": { "type": "text", "analyzer": "nori_analyzer" } }
      },
      "release_date":  { "type": "date", "format": "yyyy-MM-dd" },
      "averageRating": { "type": "float" },
      "poster_url":    { "type": "keyword" },
      "is_delete":     { "type": "boolean" }
    }
  }
}
